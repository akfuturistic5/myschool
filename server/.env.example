# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (required in production - use DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=schooldb
DB_USER=schooluser
DB_PASSWORD=your_db_password_here

# Production: full connection strings (Neon, Render, etc.)
# CRITICAL: DATABASE_URL and TENANT_ADMIN_DATABASE_URL must point to the MAIN app DB (neondb), NEVER to school_template.
# The template DB (school_template) must have ZERO persistent connections from the app; it is only used during provisioning.
#
# DATABASE_URL=postgresql://username:password@host/neondb?sslmode=require&channel_binding=require
# MASTER_DATABASE_URL=postgresql://username:password@host/master_db?sslmode=require&channel_binding=require
# TENANT_ADMIN_DATABASE_URL=postgresql://username:password@host/neondb?sslmode=require  (same as DATABASE_URL / neondb)
# PROVISIONING_TEMPLATE_DB_NAME=school_template
#
# DB_NAME: Main app DB name when DATABASE_URL not set. Local=schooldb. Neon=neondb. Must NOT be school_template.
# PROVISIONING_TEMPLATE_DB_NAME: Template DB used only in CREATE DATABASE x TEMPLATE y. App must never connect to it for normal queries.
#
# Pool size (default 5; keep low for Neon)
# DB_POOL_MAX=5
# DB_CONNECTION_TIMEOUT_MS=10000
#
# Tenant overrides
# MILLAT_DATABASE_URL=postgresql://...
# IQRA_DATABASE_URL=postgresql://...

# JWT Configuration (REQUIRED in all environments)
# Use 32+ random characters for each secret. Production: set both on the host (e.g. Render).
# Legacy: JWT_SECRET alone fills user tokens only; super-admin still needs JWT_SECRET_SUPER_ADMIN.
JWT_SECRET_USER=replace_with_strong_random_secret_for_user_tokens
JWT_SECRET_SUPER_ADMIN=replace_with_strong_random_secret_for_super_admin_tokens
JWT_EXPIRES_IN=7d

# CORS Configuration (production: comma-separated frontend origins if SPA is on another host)
# Example: https://your-app.vercel.app,https://www.yourschool.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Tenant provisioning (optional path; default is server/sql/template_schema.sql inside the image)
# PROVISIONING_TEMPLATE_SQL_PATH=sql/template_schema.sql

# Rate Limiting
RATE_LIMIT_MAX=500
LOGIN_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=debug

# Optional compatibility toggles
# ALLOW_LEGACY_BEARER_AUTH=false
# ALLOW_SUPER_ADMIN_BEARER_AUTH=false

# Cookie policy (auth + CSRF):
# - Production + CORS_ORIGIN set (typical Vercel SPA + Render API): defaults to SameSite=None; Secure
#   so browsers send cookies on credentialed API calls. If you omit CORS_ORIGIN on a same-origin deploy,
#   default stays Lax.
# - Override: COOKIE_SAME_SITE=lax|strict|none
# - Or: ALLOW_CROSS_SITE_COOKIES=true (SameSite=None in production only)
# COOKIE_SAME_SITE=lax
# ALLOW_CROSS_SITE_COOKIES=false
