# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (required in production - use DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=schooldb
DB_USER=schooluser
DB_PASSWORD=your_db_password_here

# Production preferred: use full connection strings (managed DBs like Neon)
# DATABASE_URL=postgresql://user:password@host:5432/school_db?sslmode=require&channel_binding=require
#
# DB_NAME: Primary/template DB. Local=school_db. Neon=neondb.
# DB_NAME=neondb
#
# PROVISIONING_TEMPLATE_DB_NAME: Template DB name (e.g. school_template)
# PROVISIONING_SOURCE_DATABASE_URL: REQUIRED for new schools. Use Neon DIRECT (no -pooler) to avoid "too many connections".
# PROVISIONING_ALTERNATE_SOURCE_DB: Fallback if school_template fails (default: preskool)
#
# Master DB (school registry)
# MASTER_DATABASE_URL=postgresql://user:password@host:5432/master_db?sslmode=require&channel_binding=require
#
# Tenant provisioning: connection with CREATE DATABASE. Falls back to DATABASE_URL if unset.
# TENANT_ADMIN_DATABASE_URL=postgresql://user:password@host:5432/neondb?sslmode=require&channel_binding=require
#
# Tenant DB overrides
# MILLAT_DATABASE_URL=postgresql://user:password@host:5432/neondb?sslmode=require&channel_binding=require
# IQRA_DATABASE_URL=postgresql://user:password@host:5432/iqra_db?sslmode=require&channel_binding=require
#
# Connection timeout tuning (ms)
# DB_CONNECTION_TIMEOUT_MS=20000

# JWT Configuration (REQUIRED in production - no fallback)
JWT_SECRET=your_strong_random_jwt_secret_here
JWT_EXPIRES_IN=7d

# CORS Configuration (REQUIRED in production - comma-separated allowed origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_MAX=500
LOGIN_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=debug
