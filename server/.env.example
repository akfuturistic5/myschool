# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (required in production - use DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=schooldb
DB_USER=schooluser
DB_PASSWORD=your_db_password_here

# Production: full connection strings (Neon, Render, etc.)
# CRITICAL: DATABASE_URL and TENANT_ADMIN_DATABASE_URL must point to the MAIN app DB (neondb), NEVER to school_template.
# The template DB (school_template) must have ZERO persistent connections from the app; it is only used during provisioning.
#
# DATABASE_URL=postgresql://username:password@host/neondb?sslmode=require&channel_binding=require
# MASTER_DATABASE_URL=postgresql://username:password@host/master_db?sslmode=require&channel_binding=require
# TENANT_ADMIN_DATABASE_URL=postgresql://username:password@host/neondb?sslmode=require  (same as DATABASE_URL / neondb)
# PROVISIONING_TEMPLATE_DB_NAME=school_template
# PROVISIONING_SOURCE_DATABASE_URL=postgresql://username:password@host-direct/school_template?sslmode=require  (for pg_dump only; use DIRECT endpoint)
#
# DB_NAME: Main app DB name when DATABASE_URL not set. Local=schooldb. Neon=neondb. Must NOT be school_template.
# PROVISIONING_TEMPLATE_DB_NAME: Name of template DB used only in CREATE DATABASE x TEMPLATE y. App must never connect to it for queries.
# PROVISIONING_SOURCE_DATABASE_URL: Used only by pg_dump during provisioning. Use Neon DIRECT endpoint (no -pooler).
# PROVISIONING_ALTERNATE_SOURCE_DB: (Optional) Fallback DB if template fails (default: preskool).
# PROVISIONING_RESTORE_TIMEOUT_MS: (Optional) Restore timeout in ms. Default 300000 (5 min). Increase (e.g. 600000) if restore times out.
# PROVISIONING_DUMP_TIMEOUT_MS: (Optional) pg_dump timeout in ms. Default 120000 (2 min).
#
# Pool size (default 5; keep low for Neon)
# DB_POOL_MAX=5
# DB_CONNECTION_TIMEOUT_MS=10000
#
# Tenant overrides
# MILLAT_DATABASE_URL=postgresql://...
# IQRA_DATABASE_URL=postgresql://...

# JWT Configuration (REQUIRED in production - no fallback)
JWT_SECRET=your_strong_random_jwt_secret_here
JWT_EXPIRES_IN=7d

# CORS Configuration (REQUIRED in production - comma-separated allowed origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_MAX=500
LOGIN_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=debug
