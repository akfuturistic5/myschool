# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (required in production - use DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=schooldb
DB_USER=schooluser
DB_PASSWORD=your_db_password_here

# Production: full connection strings (Neon, Render, etc.)
# CRITICAL: DATABASE_URL and TENANT_ADMIN_DATABASE_URL must point to the MAIN app DB (neondb), NEVER to school_template.
# The template DB (school_template) must have ZERO persistent connections from the app; it is only used during provisioning.
#
# DATABASE_URL=postgresql://username:password@host/neondb?sslmode=require&channel_binding=require
# MASTER_DATABASE_URL=postgresql://username:password@host/master_db?sslmode=require&channel_binding=require
# TENANT_ADMIN_DATABASE_URL=postgresql://username:password@host/neondb?sslmode=require  (same as DATABASE_URL / neondb)
# PROVISIONING_TEMPLATE_DB_NAME=school_template
# Fast school creation on Neon (clones schema from template DB — seconds instead of replaying SQL):
# PROVISIONING_USE_DB_TEMPLATE_CLONE=true
# Requires school_template (or your name) to match template_schema.sql; refresh template after schema changes.
#
# DB_NAME: Main app DB name when DATABASE_URL not set. Local=schooldb. Neon=neondb. Must NOT be school_template.
# PROVISIONING_TEMPLATE_DB_NAME: Template DB used only in CREATE DATABASE x TEMPLATE y. App must never connect to it for normal queries.
#
# Pool size (default 5; keep low for Neon)
# DB_POOL_MAX=5
# DB_CONNECTION_TIMEOUT_MS=10000
#
# Tenant overrides
# MILLAT_DATABASE_URL=postgresql://...
# IQRA_DATABASE_URL=postgresql://...

# JWT Configuration (REQUIRED in all environments)
# Use 32+ random characters for each secret. Production: set both on the host (e.g. Render).
# Legacy: JWT_SECRET alone fills user tokens only; super-admin still needs JWT_SECRET_SUPER_ADMIN.
JWT_SECRET_USER=replace_with_strong_random_secret_for_user_tokens
JWT_SECRET_SUPER_ADMIN=replace_with_strong_random_secret_for_super_admin_tokens
JWT_EXPIRES_IN=7d

# CORS Configuration — comma-separated origins allowed to call the API with credentials (no spaces)
# Local: include http://localhost:5173 (Vite)
# Production split hosting: include your SPA URL, e.g. https://my-school-dsps.onrender.com,http://localhost:5173
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
#
# ─── Render / split host: SPA on host A, API on host B (client public/config.json apiUrl = B) ───
# On the *API* service (B), you MUST set (exact origin, no trailing slash):
#   CORS_ORIGIN=https://your-spa-service.onrender.com
# Production also sets SameSite=None on auth cookies when CORS_ORIGIN is non-empty. If cookies still never attach
# to API requests (401 right after login), set explicitly on the API service:
#   COOKIE_SAME_SITE=none
#   ALLOW_CROSS_SITE_COOKIES=true
#
# If cookies still never send (401 on /api/* right after 200 login), enable Bearer on the API service:
#   TENANT_BEARER_AUTH=true
# Login response includes accessToken; the SPA stores it in sessionStorage and sends Authorization: Bearer.
# Keep CORS_ORIGIN set to the SPA. CSRF double-submit is skipped for tenant /api/* when this header is sent.
# Mitigate XSS (CSP); tokens are as sensitive as passwords.

# Tenant provisioning (optional path; default is server/sql/template_schema.sql inside the image)
# PROVISIONING_TEMPLATE_SQL_PATH=sql/template_schema.sql
# Faster tenant import when using SQL file (fewer DB round-trips). Default ~96 statements per batch; large COPY blocks stay alone.
# PROVISIONING_SQL_BATCH_SIZE=96
# PROVISIONING_SQL_LARGE_STMT_CHARS=393216
# PROVISIONING_SQL_BATCH_MAX_CHARS=921600
# PROVISIONING_SQL_BATCH_SIZE=1   # revert to one-statement-per-query if a host rejects batched SQL

# Rate Limiting
RATE_LIMIT_MAX=500
LOGIN_RATE_LIMIT_MAX=10

# Trust proxy: number of hops (default 1). Set TRUST_PROXY=false behind no proxy.
# TRUST_PROXY_HOPS=1

# Tenant DB pool cap (distinct school connections cached in memory)
# TENANT_POOL_MAX_SCHOOLS=60

# Health API (/api/health/*): set token and send header X-Health-Check-Token (or legacy X-Tenant-Health-Token).
# In production, if unset, /api/health returns 503 until configured.
# HEALTH_CHECK_TOKEN=your_long_random_token

# Provisioning template integrity (recommended in production)
# Checksum is SHA256 of template text after normalizing newlines to LF (same as Linux deploy).
# After any edit to sql/template_schema.sql, run: npm run provisioning:template-hash
# PROVISIONING_TEMPLATE_SQL_SHA256=25f0f9e9a6ca168df6acbdf994b3b1b480cd14013a64911aee01cf19bf79547f
# PROVISIONING_REQUIRE_TEMPLATE_CHECKSUM=false

# Logging
LOG_LEVEL=debug

# School logo uploads
# Default storage stays server/uploads/school-logos for local development.
# In production on Render, point this to a persistent disk mount, e.g. /var/data/myschool/school-logos
# SCHOOL_LOGO_STORAGE_ROOT=/var/data/myschool/school-logos

# Optional compatibility toggles
# ALLOW_LEGACY_BEARER_AUTH=false
# ALLOW_SUPER_ADMIN_BEARER_AUTH=false

# Cookie policy (auth + CSRF):
# - Production + CORS_ORIGIN set (typical Vercel SPA + Render API): defaults to SameSite=None; Secure
#   so browsers send cookies on credentialed API calls. If you omit CORS_ORIGIN on a same-origin deploy,
#   default stays Lax.
# - Override: COOKIE_SAME_SITE=lax|strict|none
# - Or: ALLOW_CROSS_SITE_COOKIES=true (SameSite=None in production only)
# COOKIE_SAME_SITE=lax
# ALLOW_CROSS_SITE_COOKIES=false
