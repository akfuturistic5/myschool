# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (required in production - use DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=schooldb
DB_USER=schooluser
DB_PASSWORD=your_db_password_here

# Production: full connection strings (Neon, Render, etc.)
# DATABASE_URL=postgresql://username:password@host/neondb?sslmode=require&channel_binding=require
# MASTER_DATABASE_URL=postgresql://username:password@host/master_db?sslmode=require&channel_binding=require
# TENANT_ADMIN_DATABASE_URL=postgresql://username:password@host/postgres?sslmode=require&channel_binding=require
# PROVISIONING_SOURCE_DATABASE_URL=postgresql://username:password@host/school_template?sslmode=require
#
# DB_NAME: Primary/template DB. Local=schooldb. Neon=neondb.
# PROVISIONING_TEMPLATE_DB_NAME: (Optional) Dedicated template DB name for provisioning (e.g. school_template).
# PROVISIONING_SOURCE_DATABASE_URL: Use Neon DIRECT endpoint (no -pooler) for pg_dump to avoid "too many connections".
# PROVISIONING_ALTERNATE_SOURCE_DB: (Optional) Fallback DB if template fails (default: preskool).
#
# Pool size (default 5; keep low for Neon)
# DB_POOL_MAX=5
# DB_CONNECTION_TIMEOUT_MS=10000
#
# Tenant overrides
# MILLAT_DATABASE_URL=postgresql://...
# IQRA_DATABASE_URL=postgresql://...

# JWT Configuration (REQUIRED in production - no fallback)
JWT_SECRET=your_strong_random_jwt_secret_here
JWT_EXPIRES_IN=7d

# CORS Configuration (REQUIRED in production - comma-separated allowed origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_MAX=500
LOGIN_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=debug
