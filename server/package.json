{
  "name": "preskool-server",
  "version": "1.0.0",
  "description": "PreSkool School Management System Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:restart": "node scripts/dev-restart.js",
    "provisioning:template-hash": "node scripts/provisioningTemplateHash.js",
    "db:init": "node scripts/run-init-migration.js",
    "db:setup": "node scripts/full-setup.js",
    "db:migrate": "node scripts/run-all-migrations.js",
    "db:migrate:all": "node scripts/migrate-all-tenants.js",
    "db:provision:repair": "node scripts/provision-missing-tenants.js",
    "db:migrate:master": "node scripts/run-all-migrations.js --db master_db --dir migrations/master",
    "db:seed": "node scripts/run-all-seeds.js",
    "db:seed:all": "node scripts/seed-all-tenants.js",
    "db:seed:academic": "node scripts/seed-academic.js",
    "db:init:reset": "node scripts/run-init-migration.js --reset-tenant",
    "db:verify": "node scripts/run-init-migration.js --verify-only",
    "db:migrate:student-promotions": "node scripts/run-student-promotions-migration.js",
    "db:migrate:student-promotions:reconcile": "node scripts/run-student-promotions-reconcile.js",
    "db:migrate:guardian-hardening": "node scripts/run-guardian-hardening-migration.js",
    "db:seed:master": "node scripts/ensure-master-school-registry.js",
    "db:migrate:library": "node scripts/run-library-migration.js",
    "db:migrate:accounts": "node scripts/run-accounts-migration.js",
    "db:migrate:fees": "node scripts/run-fees-migration.js",
    "db:migrate:transport": "node scripts/run-transport-migration.js",
    "db:migrate:transport-fess-allocation": "node scripts/run-transport-fess-allocation-migration.js",
    "db:migrate:hostel": "node scripts/run-hostel-migration.js",
    "db:migrate:unify": "node scripts/migrate-unify-parents-guardians.js",
    "test": "node --test \"test/**/*.test.js\"",
    "test:attendance": "node --test test/attendanceValidation.test.js"
  },
  "keywords": [
    "school",
    "management",
    "api",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "pg-copy-streams": "^7.0.0",
    "sanitize-html": "^2.13.0",
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
