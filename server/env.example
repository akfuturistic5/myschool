# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (primary/first school + master_db)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_db
DB_USER=postgres
DB_PASSWORD=your_password

# DB_NAME: Primary DB. Local: school_db. Neon: neondb.
# PROVISIONING_TEMPLATE_DB_NAME: Dedicated template (no connections). Neon: school_template.

# Optional: Master DB when hosted on Neon
# MASTER_DATABASE_URL=postgresql://user:password@host:5432/master_db?sslmode=require&channel_binding=require

# Optional: Tenant provisioning (CREATE DATABASE). Falls back to DATABASE_URL.
# TENANT_ADMIN_DATABASE_URL=postgresql://user:password@host:5432/neondb?sslmode=require&channel_binding=require

# Optional: Millat school when hosted on Neon (institute 2222)
# Set in production to connect Millat to its Neon database
# MILLAT_DATABASE_URL=postgresql://user:password@ep-sweet-mode-a1vx0r90-pooler.ap-southeast-1.aws.neon.tech:5432/neondb?sslmode=require&channel_binding=require

# Optional: Iqra school when hosted on Neon (institute 3333)
# Set in production to connect Iqra to its Neon database
# IQRA_DATABASE_URL=postgresql://user:password@ep-sweet-mode-a1vx0r90-pooler.ap-southeast-1.aws.neon.tech:5432/iqra_db?sslmode=require&channel_binding=require

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
