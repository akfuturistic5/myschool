# Server Configuration (PORT must match Vite dev proxy: default http://127.0.0.1:5001, or set client VITE_PROXY_TARGET)
NODE_ENV=development
PORT=5001

# Database Configuration (primary/first school + master_db)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_db
DB_USER=postgres
DB_PASSWORD=your_password

# Production: use full connection strings (Neon, Render)
# DATABASE_URL=postgresql://username:password@host/neondb?sslmode=require&channel_binding=require
# MASTER_DATABASE_URL=postgresql://username:password@host/master_db?sslmode=require&channel_binding=require
# TENANT_ADMIN_DATABASE_URL=postgresql://username:password@host/postgres?sslmode=require&channel_binding=require
#
# DB_NAME: Primary. Local: school_db. Neon: neondb. Must NOT be school_template.
# PROVISIONING_TEMPLATE_DB_NAME: (Optional) Template DB for CREATE DATABASE ... TEMPLATE, e.g. school_template.
# DB_POOL_MAX: (Optional) Max connections per pool, default 5.
#
# Optional: Millat / Iqra on Neon
# MILLAT_DATABASE_URL=postgresql://...
# IQRA_DATABASE_URL=postgresql://...

# JWT Configuration (server requires 32+ char secrets — see .env.example for JWT_SECRET_USER + JWT_SECRET_SUPER_ADMIN)
JWT_SECRET_USER=replace_with_strong_random_secret_for_user_tokens
JWT_SECRET_SUPER_ADMIN=replace_with_strong_random_secret_for_super_admin_tokens
JWT_EXPIRES_IN=7d

# CORS Configuration (include Vite: http://localhost:5173)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=debug
